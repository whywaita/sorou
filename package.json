{
  "name": "sorou",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute sorou-db --local --file=./drizzle/migrations/*.sql",
    "db:migrate:prod": "wrangler d1 execute sorou-db --remote --file=./drizzle/migrations/*.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.42.0",
    "@hono/zod-validator": "^0.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250515.0",
    "wrangler": "^4.21.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0"
  }
}
